# HostelX Backend Environment Variables
# Copy this file to .env and configure these variables for production/development.

# Server listening port
PORT=5000

# MongoDB Connection String (e.g., MongoDB Atlas or local MongoDB)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/hostelx?retryWrites=true&w=majority

# Secret key for generating JWT tokens
JWT_SECRET=your_super_secret_jwt_key_here

# Cloudinary credentials for hosting product & profile images
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Dynamic Frontend Allowed Origins (Comma separated URLs)
# Add your custom Vercel domain here!
FRONTEND_URL=https://hostelx-pi.vercel.app,http://localhost:5173
